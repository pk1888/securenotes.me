# Database Encryption (REQUIRED - 256-bit encryption key for SQLCipher)
# Generate a secure key with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DB_ENCRYPTION_KEY=your-64-character-hex-key-here-generate-with-crypto-randomBytes-32

# Application-level encryption secret for message content
ENCRYPTION_SECRET=your-app-encryption-secret-here

# Node Environment
NODE_ENV=development

# App URL (for production)
APP_URL=http://localhost:3000
